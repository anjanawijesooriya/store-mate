generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ShopCategory {
  GROCERY
  SUPERMARKET
  PHARMACY
  CLOTHING
  FASHION_ACCESSORIES
  HARDWARE
  MOBILE_PHONES
  ELECTRONICS
  SALON
  FOOD_BEVERAGE
  STATIONERY
  FURNITURE
  JEWELLERY
  OTHER
}

enum PlanTier {
  BASIC
  STANDARD
  PREMIUM
}

enum Role {
  OWNER
  CASHIER
}

enum MovementType {
  SALE
  RESTOCK
  ADJUSTMENT
  RETURN
  DAMAGE
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
  CREDIT
}

enum SaleStatus {
  COMPLETED
  PENDING_PAYMENT
  EXCHANGED
  REFUNDED
  VOIDED
}

enum SmsType {
  LOW_STOCK
  DAILY_SUMMARY
  RECEIPT
  OTP
}

enum BillingStatus {
  TRIAL
  ACTIVE
  GRACE
  LOCKED
}

enum PayType {
  SALARY
  HOURLY
  DAILY
}

enum RecordPeriod {
  DAY
  WEEK
  MONTH
}

enum RecordStatus {
  PENDING
  PAID
}

enum DeductionType {
  EPF
  ETF
  ADVANCE
  CUSTOM
}

// Reserved for future Branch Mode — links multiple shops under one owner.
// Nullable so all existing shops are unaffected until they opt in.
model ShopGroup {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  shops     Shop[]
}

model Shop {
  id                String       @id @default(cuid())
  name              String
  ownerName         String
  phone             String       @unique
  category          ShopCategory
  address           String?
  planTier          PlanTier     @default(BASIC)
  trialEndsAt       DateTime?
  smsAddonEnabled      Boolean      @default(false)
  smsLowStock          Boolean      @default(true)
  smsDailySummary      Boolean      @default(true)
  smsReceiptEnabled    Boolean      @default(false)
  emailLowStock        Boolean      @default(true)
  emailDailySummary    Boolean      @default(true)
  emailReceiptEnabled  Boolean      @default(true)
  creditReminderEnabled Boolean     @default(false)
  variantsEnabled       Boolean     @default(false)
  smsBalance        Decimal      @default(0) @db.Decimal(10, 2)
  billingStatus          BillingStatus @default(TRIAL)
  gracePeriodEndsAt      DateTime?
  nextBillingDate        DateTime?
  maintenanceBanner      Boolean       @default(false)
  maintenanceBannerMessage String?
  cardSurchargeEnabled   Boolean       @default(false)
  cardSurchargeRate      Decimal       @default(0) @db.Decimal(5,4)
  branchModeEnabled      Boolean       @default(false)
  deviceLockEnabled      Boolean       @default(false)
  isLifetime             Boolean       @default(false)
  maintenanceDueDate     DateTime?
  maintenancePaidUntil   DateTime?
  payrollEnabled         Boolean       @default(false)
  // Branch Mode — null means standalone shop, set when owner links branches
  shopGroupId       String?
  shopGroup         ShopGroup?   @relation(fields: [shopGroupId], references: [id])
  createdAt         DateTime     @default(now())
  users             User[]
  products          Product[]
  sales             Sale[]
  customers         Customer[]
  expenses          Expense[]
  smsLogs           SmsLog[]
  payments             Payment[]
  maintenancePayments  MaintenancePayment[]
  devices              DeviceSession[]
  employees            Employee[]
  payrollRecords       PayrollRecord[]

  @@index([shopGroupId])
}

model DeviceSession {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  userId      String
  deviceId    String
  deviceName  String?
  isPrimary   Boolean  @default(false)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([shopId, deviceId])
  @@index([shopId])
}

model SmsLog {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id])
  to        String
  type      SmsType
  message   String
  status    String
  error     String?
  createdAt DateTime @default(now())

  @@index([shopId, createdAt])
}

model User {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id])
  name         String
  phone        String   @unique
  email        String?
  passwordHash String
  role         Role     @default(OWNER)
  createdAt    DateTime @default(now())

  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Product {
  id         String          @id @default(cuid())
  shopId     String
  shop       Shop            @relation(fields: [shopId], references: [id])
  name       String
  itemCode   String?
  sku        String?
  category   String?
  unit       String          @default("pcs")
  costPrice  Decimal         @db.Decimal(10, 2)
  sellPrice  Decimal         @db.Decimal(10, 2)
  stockQty   Decimal         @db.Decimal(10, 2) @default(0)
  lowStockAt Decimal         @db.Decimal(10, 2) @default(5)
  imageUrl        String?
  warrantyPeriod  String?
  isService       Boolean         @default(false)
  isActive        Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  movements  StockMovement[]
  saleItems  SaleItem[]
  variants   ProductVariant[]

  @@index([shopId])
  @@unique([shopId, sku])
  @@unique([shopId, itemCode])
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size       String
  color      String?
  sku        String?
  stockQty   Decimal  @db.Decimal(10, 2) @default(0)
  lowStockAt Decimal  @db.Decimal(10, 2) @default(3)
  sellPrice  Decimal? @db.Decimal(10, 2)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, size, color])
  @@index([productId])
}

model StockMovement {
  id        String       @id @default(cuid())
  productId String
  product   Product      @relation(fields: [productId], references: [id])
  type      MovementType
  quantity  Decimal      @db.Decimal(10, 2)
  note      String?
  createdAt DateTime     @default(now())
}

model Customer {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id])
  name          String
  phone         String?
  email         String?
  address       String?
  creditBalance Decimal  @db.Decimal(10, 2) @default(0)
  totalSpent    Decimal  @db.Decimal(10, 2) @default(0)
  sales         Sale[]
  createdAt     DateTime @default(now())

  @@index([shopId])
}

model Sale {
  id             String        @id @default(cuid())
  shopId         String
  shop           Shop          @relation(fields: [shopId], references: [id])
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])
  userId         String
  items          SaleItem[]
  subtotal       Decimal       @db.Decimal(10, 2)
  discount       Decimal       @db.Decimal(10, 2) @default(0)
  total          Decimal       @db.Decimal(10, 2)
  paymentMethod  PaymentMethod
  amountPaid     Decimal       @db.Decimal(10, 2)
  cardFee        Decimal       @default(0) @db.Decimal(10, 2)
  cardFeeRate    Decimal       @default(0) @db.Decimal(5, 4)
  status         SaleStatus    @default(COMPLETED)
  originalSaleId String?
  originalSale   Sale?         @relation("ExchangeOf", fields: [originalSaleId], references: [id])
  exchanges      Sale[]        @relation("ExchangeOf")
  createdAt      DateTime      @default(now())

  @@index([shopId, createdAt])
  @@index([originalSaleId])
}

model SaleItem {
  id           String  @id @default(cuid())
  saleId       String
  sale         Sale    @relation(fields: [saleId], references: [id])
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  variantLabel String?
  quantity     Decimal @db.Decimal(10, 2)
  unitPrice    Decimal @db.Decimal(10, 2)
  lineTotal    Decimal @db.Decimal(10, 2)
  returned     Boolean @default(false)
}

model Expense {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  category    String
  amount      Decimal  @db.Decimal(10, 2)
  note        String?
  receiptUrl  String?
  expenseDate DateTime
  createdAt   DateTime @default(now())

  @@index([shopId, expenseDate])
}

model Payment {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id])
  amount       Decimal  @db.Decimal(10, 2)
  currency     String   @default("LKR")
  method       String   @default("MANUAL")
  reference    String?
  planTier     PlanTier
  billingMonth String
  note         String?
  paidAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([shopId])
}

model MaintenancePayment {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("LKR")
  method      String   @default("MANUAL")
  reference   String?
  note        String?
  periodStart DateTime
  periodEnd   DateTime
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([shopId])
}

model BackupLog {
  id        String   @id @default(cuid())
  type      String
  status    String
  fileId    String?
  fileName  String?
  fileSize  Int?
  driveUrl  String?
  error     String?
  createdAt DateTime @default(now())
}

model Employee {
  id        String         @id @default(cuid())
  shopId    String
  shop      Shop           @relation(fields: [shopId], references: [id])
  name      String
  phone     String?
  email     String?
  nic       String?
  position  String?
  payType   PayType
  payRate   Decimal        @db.Decimal(10, 2)
  joinDate  DateTime?
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  records   PayrollRecord[]

  @@index([shopId])
}

model PayrollRecord {
  id              String             @id @default(cuid())
  shopId          String
  shop            Shop               @relation(fields: [shopId], references: [id])
  employeeId      String
  employee        Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  periodType      RecordPeriod
  periodStart     DateTime
  periodEnd       DateTime
  hoursWorked     Decimal?           @db.Decimal(6, 2)
  grossAmount     Decimal            @db.Decimal(10, 2)
  totalDeductions Decimal            @db.Decimal(10, 2) @default(0)
  netAmount       Decimal            @db.Decimal(10, 2)
  status          RecordStatus       @default(PENDING)
  paidAt          DateTime?
  note            String?
  deductions      PayrollDeduction[]
  createdAt       DateTime           @default(now())

  @@index([shopId, periodStart])
  @@index([employeeId])
}

model PayrollDeduction {
  id              String        @id @default(cuid())
  payrollRecordId String
  record          PayrollRecord @relation(fields: [payrollRecordId], references: [id], onDelete: Cascade)
  type            DeductionType
  label           String
  amount          Decimal       @db.Decimal(10, 2)
}
