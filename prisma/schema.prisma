generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ShopCategory {
  GROCERY
  SUPERMARKET
  PHARMACY
  CLOTHING
  FASHION_ACCESSORIES
  HARDWARE
  MOBILE_PHONES
  ELECTRONICS
  SALON
  FOOD_BEVERAGE
  STATIONERY
  FURNITURE
  JEWELLERY
  OTHER
}

enum PlanTier {
  BASIC
  STANDARD
  PREMIUM
}

enum Role {
  OWNER
  CASHIER
}

enum MovementType {
  SALE
  RESTOCK
  ADJUSTMENT
  RETURN
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
  CREDIT
}

enum SaleStatus {
  COMPLETED
  PENDING_PAYMENT
  EXCHANGED
  REFUNDED
  VOIDED
}

enum SmsType {
  LOW_STOCK
  DAILY_SUMMARY
  RECEIPT
  OTP
}

enum BillingStatus {
  TRIAL
  ACTIVE
  GRACE
  LOCKED
}

model Shop {
  id                String       @id @default(cuid())
  name              String
  ownerName         String
  phone             String       @unique
  category          ShopCategory
  address           String?
  planTier          PlanTier     @default(BASIC)
  trialEndsAt       DateTime?
  smsAddonEnabled   Boolean      @default(false)
  smsLowStock       Boolean      @default(true)
  smsDailySummary   Boolean      @default(true)
  smsReceiptEnabled Boolean      @default(false)
  smsCredits        Int          @default(0)
  billingStatus     BillingStatus @default(TRIAL)
  gracePeriodEndsAt DateTime?
  nextBillingDate   DateTime?
  createdAt         DateTime     @default(now())
  users             User[]
  products          Product[]
  sales             Sale[]
  customers         Customer[]
  expenses          Expense[]
  smsLogs           SmsLog[]
  payments          Payment[]
  devices           DeviceSession[]
}

model DeviceSession {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  userId      String
  deviceId    String
  deviceName  String?
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([shopId, deviceId])
  @@index([shopId])
}

model SmsLog {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id])
  to        String
  type      SmsType
  message   String
  status    String
  error     String?
  createdAt DateTime @default(now())

  @@index([shopId, createdAt])
}

model User {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id])
  name         String
  phone        String   @unique
  passwordHash String
  role         Role     @default(OWNER)
  createdAt    DateTime @default(now())
}

model Product {
  id         String          @id @default(cuid())
  shopId     String
  shop       Shop            @relation(fields: [shopId], references: [id])
  name       String
  sku        String?
  category   String?
  unit       String          @default("pcs")
  costPrice  Decimal         @db.Decimal(10, 2)
  sellPrice  Decimal         @db.Decimal(10, 2)
  stockQty   Decimal         @db.Decimal(10, 2) @default(0)
  lowStockAt Decimal         @db.Decimal(10, 2) @default(5)
  imageUrl   String?
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  movements  StockMovement[]
  saleItems  SaleItem[]

  @@index([shopId])
  @@unique([shopId, sku])
}

model StockMovement {
  id        String       @id @default(cuid())
  productId String
  product   Product      @relation(fields: [productId], references: [id])
  type      MovementType
  quantity  Decimal      @db.Decimal(10, 2)
  note      String?
  createdAt DateTime     @default(now())
}

model Customer {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id])
  name          String
  phone         String?
  address       String?
  creditBalance Decimal  @db.Decimal(10, 2) @default(0)
  totalSpent    Decimal  @db.Decimal(10, 2) @default(0)
  sales         Sale[]
  createdAt     DateTime @default(now())

  @@index([shopId])
}

model Sale {
  id             String        @id @default(cuid())
  shopId         String
  shop           Shop          @relation(fields: [shopId], references: [id])
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])
  userId         String
  items          SaleItem[]
  subtotal       Decimal       @db.Decimal(10, 2)
  discount       Decimal       @db.Decimal(10, 2) @default(0)
  total          Decimal       @db.Decimal(10, 2)
  paymentMethod  PaymentMethod
  amountPaid     Decimal       @db.Decimal(10, 2)
  status         SaleStatus    @default(COMPLETED)
  originalSaleId String?
  originalSale   Sale?         @relation("ExchangeOf", fields: [originalSaleId], references: [id])
  exchanges      Sale[]        @relation("ExchangeOf")
  createdAt      DateTime      @default(now())

  @@index([shopId, createdAt])
  @@index([originalSaleId])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Decimal @db.Decimal(10, 2)
  unitPrice Decimal @db.Decimal(10, 2)
  lineTotal Decimal @db.Decimal(10, 2)
  returned  Boolean @default(false)
}

model Expense {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  category    String
  amount      Decimal  @db.Decimal(10, 2)
  note        String?
  receiptUrl  String?
  expenseDate DateTime
  createdAt   DateTime @default(now())

  @@index([shopId, expenseDate])
}

model Payment {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id])
  amount       Decimal  @db.Decimal(10, 2)
  currency     String   @default("LKR")
  method       String   @default("MANUAL")
  reference    String?
  planTier     PlanTier
  billingMonth String
  note         String?
  paidAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([shopId])
}
